# ═══════════════════════════════════════════════════════════════
#  EduVideo Platform — Environment Configuration (MySQL)
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database (MySQL) ────────────────────────────────────────────
MYSQL_DATABASE=eduvideo
MYSQL_USER=eduvideo
MYSQL_PASSWORD=eduvideo_dev_password
MYSQL_ROOT_PASSWORD=root_password
DATABASE_URL=mysql://root:root_password@localhost:3306/eduvideo

# ─── JWT Auth ────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_TOO_MAKE_IT_DIFFERENT
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password

# ─── Storage ─────────────────────────────────────────────────────
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads
STORAGE_BASE_URL=http://localhost:3001

# AWS S3 / MinIO
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=eduvideo
AWS_ENDPOINT=http://localhost:9000

# ─── MinIO ────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ─── AI / TTS ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ELEVENLABS_API_KEY=
DID_API_KEY=

# ─── FFmpeg ──────────────────────────────────────────────────────
FFMPEG_PATH=ffmpeg
FFMPEG_TEMP_DIR=/tmp/edu-video

# ─── Worker ──────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ─── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
